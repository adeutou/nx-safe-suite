{
  "name": "@nx-safe-suite/server-cache",
  "version": "0.1.0",
  "description": "Multi-tier (memory → Redis → source) server-side cache for Next.js with TTL, tag-based invalidation, stale-while-revalidate, and stampede protection.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "echo \"(lint not yet configured)\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adeutou/nx-safe-suite.git",
    "directory": "packages/server-cache"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "cache",
    "redis",
    "lru",
    "ttl",
    "tags",
    "stale-while-revalidate"
  ],
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
