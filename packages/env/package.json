{
  "name": "@nx-safe-suite/env",
  "version": "0.0.1",
  "description": "Strict, type-safe environment variable validation for Next.js, powered by Zod.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "echo \"(lint not yet configured)\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adeutou/nx-safe-suite.git",
    "directory": "packages/env"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "env",
    "environment-variables",
    "zod",
    "validation"
  ],
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  }
}
